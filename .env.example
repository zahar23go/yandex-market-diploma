# Yandex Market Test Configuration

# URLs
BASE_URL=https://market.yandex.ru
API_BASE_URL=https://api.market.yandex.ru

# API Authentication
API_KEY=your_api_key_here

# Browser settings
BROWSER=chrome
HEADLESS=false
WINDOW_WIDTH=1920
WINDOW_HEIGHT=1080

# Timeouts (seconds)
IMPLICIT_WAIT=10
EXPLICIT_WAIT=20

# Test data
SEARCH_QUERY=iPhone 15
MIN_PRICE=50000
MAX_PRICE=100000

# Test account (optional)
TEST_EMAIL=
TEST_PASSWORD=
